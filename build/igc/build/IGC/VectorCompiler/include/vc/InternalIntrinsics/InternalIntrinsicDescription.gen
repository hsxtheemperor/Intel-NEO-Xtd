// Add parameter attributes that are not common to all intrinsics.
#ifdef GET_INTRINSIC_ATTRIBUTES
AttributeList InternalIntrinsic::getAttributes(LLVMContext &C, InternalIntrinsic::ID id) {
  static const uint8_t IntrinsicsToAttributesMap[] = {
    1, // llvm.vc.internal.assert.buffer
    2, // llvm.vc.internal.atomic.fmax
    2, // llvm.vc.internal.atomic.fmin
    3, // llvm.vc.internal.cast.from.bf16
    3, // llvm.vc.internal.cast.to.bf16
    3, // llvm.vc.internal.cast.to.ptr.explicit
    3, // llvm.vc.internal.jump.table
    3, // llvm.vc.internal.logical.thread.id
    2, // llvm.vc.internal.lsc.atomic.bss
    2, // llvm.vc.internal.lsc.atomic.bti
    2, // llvm.vc.internal.lsc.atomic.slm
    2, // llvm.vc.internal.lsc.atomic.ugm
    1, // llvm.vc.internal.lsc.load.2d.tgm.bti
    1, // llvm.vc.internal.lsc.load.2d.ugm.desc
    1, // llvm.vc.internal.lsc.load.2d.ugm.desc.transpose
    1, // llvm.vc.internal.lsc.load.2d.ugm.desc.vnni
    1, // llvm.vc.internal.lsc.load.block.2d.ugm
    1, // llvm.vc.internal.lsc.load.block.2d.ugm.transposed
    1, // llvm.vc.internal.lsc.load.block.2d.ugm.vnni
    1, // llvm.vc.internal.lsc.load.bss
    1, // llvm.vc.internal.lsc.load.bti
    1, // llvm.vc.internal.lsc.load.quad.bss
    1, // llvm.vc.internal.lsc.load.quad.bti
    1, // llvm.vc.internal.lsc.load.quad.slm
    1, // llvm.vc.internal.lsc.load.quad.tgm
    1, // llvm.vc.internal.lsc.load.quad.ugm
    1, // llvm.vc.internal.lsc.load.slm
    1, // llvm.vc.internal.lsc.load.ugm
    2, // llvm.vc.internal.lsc.prefetch.2d.ugm.desc
    2, // llvm.vc.internal.lsc.prefetch.block.2d.ugm
    2, // llvm.vc.internal.lsc.prefetch.bss
    2, // llvm.vc.internal.lsc.prefetch.bti
    2, // llvm.vc.internal.lsc.prefetch.quad.bss
    2, // llvm.vc.internal.lsc.prefetch.quad.bti
    2, // llvm.vc.internal.lsc.prefetch.quad.tgm
    2, // llvm.vc.internal.lsc.prefetch.quad.ugm
    2, // llvm.vc.internal.lsc.prefetch.ugm
    4, // llvm.vc.internal.lsc.store.2d.tgm.bti
    4, // llvm.vc.internal.lsc.store.2d.ugm.desc
    4, // llvm.vc.internal.lsc.store.block.2d.ugm
    4, // llvm.vc.internal.lsc.store.bss
    4, // llvm.vc.internal.lsc.store.bti
    4, // llvm.vc.internal.lsc.store.quad.bss
    4, // llvm.vc.internal.lsc.store.quad.bti
    4, // llvm.vc.internal.lsc.store.quad.slm
    4, // llvm.vc.internal.lsc.store.quad.tgm
    4, // llvm.vc.internal.lsc.store.quad.ugm
    4, // llvm.vc.internal.lsc.store.slm
    4, // llvm.vc.internal.lsc.store.ugm
    1, // llvm.vc.internal.print.buffer
    3, // llvm.vc.internal.print.format.index
    1, // llvm.vc.internal.read.variable.region
    3, // llvm.vc.internal.round.to.tf32
    3, // llvm.vc.internal.stochastic.round.to.f16
    1, // llvm.vc.internal.sync.buffer
    4, // llvm.vc.internal.write.variable.region
  };

  unsigned AttrIdx = id - 1 - InternalIntrinsic::not_internal_intrinsic;
  #ifndef NDEBUG
  const size_t AttrMapNum = sizeof(IntrinsicsToAttributesMap)/sizeof(IntrinsicsToAttributesMap[0]);
  IGC_ASSERT(AttrIdx < AttrMapNum && "invalid attribute index");
  #endif // NDEBUG
  AttributeList AS[1];
  unsigned NumAttrs = 0;
  if (id != 0) {
    switch(IntrinsicsToAttributesMap[AttrIdx]) {
    default: IGC_ASSERT_EXIT_MESSAGE(0, "Invalid attribute number");
    case 1: {
      const Attribute::AttrKind Atts[] = {Attribute::NoUnwind,Attribute::ReadOnly};
      AS[0] = AttributeList::get(C, AttributeList::FunctionIndex, Atts);
      NumAttrs = 1;
      break;
      }
    case 2: {
      const Attribute::AttrKind Atts[] = {Attribute::NoUnwind};
      AS[0] = AttributeList::get(C, AttributeList::FunctionIndex, Atts);
      NumAttrs = 1;
      break;
      }
    case 3: {
      const Attribute::AttrKind Atts[] = {Attribute::NoUnwind,Attribute::ReadNone};
      AS[0] = AttributeList::get(C, AttributeList::FunctionIndex, Atts);
      NumAttrs = 1;
      break;
      }
    case 4: {
      const Attribute::AttrKind Atts[] = {Attribute::NoUnwind,Attribute::WriteOnly};
      AS[0] = AttributeList::get(C, AttributeList::FunctionIndex, Atts);
      NumAttrs = 1;
      break;
      }
    }
  }
  return AttributeList::get(C, ArrayRef(AS, NumAttrs));
}
#endif // GET_INTRINSIC_ATTRIBUTES

