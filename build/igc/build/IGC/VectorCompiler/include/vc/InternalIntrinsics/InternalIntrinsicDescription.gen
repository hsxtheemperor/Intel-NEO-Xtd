// Checker for platform features
#ifdef GET_INTRINSIC_TARGET_FEATURE_CHECKER
unsigned Index = ID - 1 - vc::InternalIntrinsic::not_internal_intrinsic;
auto MaskRequired = RequiredTargetFeatures[Index];
auto MaskForbidden = ForbiddenTargetFeatures[Index];
if ((MaskRequired & 1) && !hasLSCMessages()) return false;
if ((MaskForbidden & 1) && hasLSCMessages()) return false;
if ((MaskRequired & 2) && !hasLSCTypedMessages()) return false;
if ((MaskForbidden & 2) && hasLSCTypedMessages()) return false;
#endif // GET_INTRINSIC_TARGET_FEATURE_CHECKER

