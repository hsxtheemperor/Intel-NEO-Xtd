  346                       | SrcImmOperand
  347                       | SrcAddrOfOperand

  348 VecSrcOperand_G_A: VecSrcOperand_G
  349                  | SrcAddrOperand

  350 VecSrcOperand_G_A_AO: VecSrcOperand_G_A
  351                     | SrcAddrOfOperand

  352 VecSrcOperand_G: SrcGeneralOperand

  353 VecSrcOpndSimple: Var TwoDimOffset

  354 VMEOpndIME: LPAREN DEC_LIT COMMA DEC_LIT RPAREN

  355 VMEOpndFBR: LPAREN VecSrcOperand_G_I_IMM COMMA VecSrcOperand_G_I_IMM COMMA VecSrcOperand_G_I_IMM RPAREN

  356 SrcStateOperand: Var LPAREN IntExp RPAREN

  357 DstStateOperand: Var LPAREN IntExp RPAREN

  358 RawOperand: RawOperandNonNull
  359           | BUILTIN_NULL DOT DEC_LIT

  360 RawOperandNonNull: VarNonNull RawOperandOffsetSuffix

  361 RawOperandOffsetSuffix: DOT DEC_LIT
  362                       | DOT LPAREN IntExp RPAREN

  363 RawOperandArray: ε
  364                | RawOperandArray RawOperand

  365 DstAddrOperand: AddrVarAccessWithWidth

  366 DstGeneralOperand: Var TwoDimOffset DstRegion
  367                  | Var DstRegion

  368 DstIndirectOperand: IndirectVarAccess DstRegion DataType

  369 SrcAddrOfOperand: AddrOfVar
  370                 | AddrOfVar LBRACK IntExp RBRACK

  371 AddrOfVar: AMP Var

  372 SrcAddrOperand: AddrVarAccessWithWidth

  373 SrcGeneralOperand: Var TwoDimOffset SrcRegionDirect
  374                  | SrcModifier Var TwoDimOffset SrcRegionDirect

  375 SrcImmOperand: IntExpUnr DataTypeIntOrVector
  376              | HEX_LIT HFTYPE
  377              | FloatLit
  378              | MINUS FloatLit
  379              | DoubleFloatLit
  380              | MINUS DoubleFloatLit

  381 FloatLit: F32_LIT
  382         | DEC_LIT FTYPE
  383         | HEX_LIT FTYPE

  384 DoubleFloatLit: F64_LIT
  385               | DEC_LIT DFTYPE
  386               | HEX_LIT DFTYPE

  387 SrcIndirectOperand: IndirectVarAccess SrcRegionIndirect DataType
  388                   | SrcModifier IndirectVarAccess SrcRegionIndirect DataType

  389 DstRegion: LANGLE IntExpNRA RANGLE

  390 SrcRegionDirect: LANGLE IntExp SEMI IntExp COMMA IntExpNRA RANGLE

  391 SrcRegionIndirect: SrcRegionDirect
  392                  | LANGLE IntExp COMMA DEC_LIT RANGLE
  393                  | LANGLE IntExpNRA RANGLE

  394 IndirectVarAccess: IND_LBRACK AddrVarAccess COMMA IntExp RBRACK
  395                  | IND_LBRACK AddrVarAccess RBRACK

  396 TwoDimOffset: LPAREN IntExp COMMA IntExp RPAREN

  397 PredVar: Var

  398 AddrVarAccess: Var LPAREN IntExp RPAREN

  399 AddrVarAccessWithWidth: Var LPAREN IntExp RPAREN LANGLE IntExpNRA RANGLE

  400 SIMDMode: ε
  401         | LPAREN DEC_LIT RPAREN

  402 ElemNum: DOT DEC_LIT

  403 ExecSize: LPAREN ExecSizeInt RPAREN
  404         | LPAREN Var COMMA ExecSizeInt RPAREN

  405 ExecSizeInt: DEC_LIT

  406 Var: VarNonNull
  407    | BUILTIN_NULL

  408 VarNonNull: IDENT
  409           | BUILTIN

  410 IntExp: IntExpCond

  411 IntExpCond: IntExpAND QUESTION IntExpAND COLON IntExpCond
  412           | IntExpAND

  413 IntExpAND: IntExpAND AMP IntExpXOR
  414          | IntExpXOR

  415 IntExpXOR: IntExpXOR CIRC IntExpOR
  416          | IntExpOR

  417 IntExpOR: IntExpOR PIPE IntExpCmp
  418         | IntExpCmp

  419 IntExpCmp: IntExpRel EQ IntExpRel
  420          | IntExpRel NEQ IntExpRel
  421          | IntExpRel

  422 IntExpRel: IntExpNRA LANGLE IntExpNRA
  423          | IntExpNRA RANGLE IntExpNRA
  424          | IntExpNRA LEQ IntExpNRA
  425          | IntExpNRA GEQ IntExpNRA
  426          | IntExpNRA

  427 IntExpNRA: IntExpShift

  428 IntExpShift: IntExpAdd SHL IntExpAdd
  429            | IntExpAdd SHRS IntExpAdd
  430            | IntExpAdd SHRZ IntExpAdd
  431            | IntExpAdd

  432 IntExpAdd: IntExpAdd PLUS IntExpMul
  433          | IntExpAdd MINUS IntExpMul
  434          | IntExpMul

  435 IntExpMul: IntExpMul TIMES IntExpUnr
  436          | IntExpMul SLASH IntExpUnr
  437          | IntExpMul PERCENT IntExpUnr
  438          | IntExpUnr

  439 IntExpUnr: MINUS IntExpUnr
  440          | TILDE IntExpUnr
  441          | BANG IntExpUnr
  442          | IntExpPrim

  443 IntExpPrim: DEC_LIT
  444           | HEX_LIT
  445           | LPAREN IntExp RPAREN
  446           | BUILTIN_SIZEOF IDENT
  447           | BUILTIN_SIZEOF LPAREN IDENT RPAREN
  448           | BUILTIN_DISPATCH_SIMD_SIZE

  449 DataType: DataTypeIntOrVector
  450         | DFTYPE
  451         | FTYPE
  452         | HFTYPE
  453         | BFTYPE

  454 DataTypeIntOrVector: ITYPE
  455                    | VTYPE


