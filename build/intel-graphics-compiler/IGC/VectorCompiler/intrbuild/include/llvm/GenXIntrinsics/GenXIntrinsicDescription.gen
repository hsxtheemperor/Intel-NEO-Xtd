    3, // llvm.genx.zzzzend
  };

  unsigned AttrIdx = id - 1 - GenXIntrinsic::not_genx_intrinsic;
  #ifndef NDEBUG
  const size_t AttrMapNum = sizeof(IntrinsicsToAttributesMap)/sizeof(IntrinsicsToAttributesMap[0]);
  assert(AttrIdx < AttrMapNum && "invalid attribute index");
  #endif // NDEBUG
  AttributeList AS[1];
  unsigned NumAttrs = 0;
  if (id != 0) {
    switch(IntrinsicsToAttributesMap[AttrIdx]) {
    default: llvm_unreachable("Invalid attribute number");
    case 1: {
      #if LLVM_VERSION_MAJOR >= 16
      AttrBuilder Atts(C);
      Atts.addAttribute(Attribute::NoUnwind).addMemoryAttr(MemoryEffects::readOnly()).addAttribute(Attribute::WillReturn);
      #else
      const Attribute::AttrKind Atts[] = {Attribute::NoUnwind,Attribute::ReadOnly};
      #endif
      AS[0] = AttributeList::get(C, AttributeList::FunctionIndex, Atts);
      NumAttrs = 1;
      break;
      }
    case 2: {
      #if LLVM_VERSION_MAJOR >= 16
      AttrBuilder Atts(C);
      Atts.addAttribute(Attribute::NoUnwind).addMemoryAttr(MemoryEffects::none()).addAttribute(Attribute::WillReturn);
      #else
      const Attribute::AttrKind Atts[] = {Attribute::NoUnwind,Attribute::ReadNone};
      #endif
      AS[0] = AttributeList::get(C, AttributeList::FunctionIndex, Atts);
      NumAttrs = 1;
      break;
      }
    case 3: {
      #if LLVM_VERSION_MAJOR >= 16
      AttrBuilder Atts(C);
      Atts.addAttribute(Attribute::NoUnwind).addAttribute(Attribute::WillReturn);
      #else
      const Attribute::AttrKind Atts[] = {Attribute::NoUnwind};
      #endif
      AS[0] = AttributeList::get(C, AttributeList::FunctionIndex, Atts);
      NumAttrs = 1;
      break;
      }
    case 4: {
      #if LLVM_VERSION_MAJOR >= 16
      AttrBuilder Atts(C);
      Atts.addAttribute(Attribute::Convergent).addAttribute(Attribute::NoUnwind).addAttribute(Attribute::WillReturn);
      #else
      const Attribute::AttrKind Atts[] = {Attribute::Convergent,Attribute::NoUnwind};
      #endif
      AS[0] = AttributeList::get(C, AttributeList::FunctionIndex, Atts);
      NumAttrs = 1;
      break;
      }
    case 5: {
      #if LLVM_VERSION_MAJOR >= 16
      AttrBuilder Atts(C);
      Atts.addAttribute(Attribute::NoUnwind);
      #else
      const Attribute::AttrKind Atts[] = {Attribute::NoUnwind};
      #endif
      AS[0] = AttributeList::get(C, AttributeList::FunctionIndex, Atts);
      NumAttrs = 1;
      break;
      }
    case 6: {
      #if LLVM_VERSION_MAJOR >= 16
      AttrBuilder Atts(C);
      Atts.addAttribute(Attribute::NoUnwind).addAttribute(Attribute::WillReturn);
      #else
      const Attribute::AttrKind Atts[] = {Attribute::NoUnwind};
      #endif
      AS[0] = AttributeList::get(C, AttributeList::FunctionIndex, Atts);
      NumAttrs = 1;
      break;
      }
    case 7: {
      #if LLVM_VERSION_MAJOR >= 16
      AttrBuilder Atts(C);
      Atts.addAttribute(Attribute::NoUnwind).addMemoryAttr(MemoryEffects::writeOnly()).addAttribute(Attribute::WillReturn);
      #else
      const Attribute::AttrKind Atts[] = {Attribute::NoUnwind,Attribute::WriteOnly};
      #endif
      AS[0] = AttributeList::get(C, AttributeList::FunctionIndex, Atts);
      NumAttrs = 1;
      break;
      }
    case 8: {
      #if LLVM_VERSION_MAJOR >= 16
      AttrBuilder Atts(C);
      Atts.addAttribute(Attribute::NoUnwind);
      #else
      const Attribute::AttrKind Atts[] = {Attribute::NoUnwind};
      #endif
      AS[0] = AttributeList::get(C, AttributeList::FunctionIndex, Atts);
      NumAttrs = 1;
      break;
      }
    case 9: {
      #if LLVM_VERSION_MAJOR >= 16
      AttrBuilder Atts(C);
      Atts.addAttribute(Attribute::NoUnwind).addMemoryAttr(MemoryEffects::writeOnly()).addAttribute(Attribute::WillReturn);
      #else
      const Attribute::AttrKind Atts[] = {Attribute::NoUnwind,Attribute::WriteOnly};
      #endif
      AS[0] = AttributeList::get(C, AttributeList::FunctionIndex, Atts);
      NumAttrs = 1;
      break;
      }
    }
  }
  return AttributeList::get(C, ArrayRef<AttributeList>(AS, NumAttrs));
}
